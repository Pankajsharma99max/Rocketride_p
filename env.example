# Core RocketRide connection (auto-populated by the VS Code extension into .env;
# set these manually if you're running standalone without the extension)
ROCKETRIDE_URI=http://localhost:5565
ROCKETRIDE_APIKEY=your-rocketride-api-key-here

# LLM used by the query pipeline (pipeline/query.pipe)
ROCKETRIDE_GEMINI_KEY=your-gemini-api-key-here

# Vector store used by both pipelines (must match between ingestion.pipe and query.pipe)
ROCKETRIDE_QDRANT_HOST=localhost
ROCKETRIDE_QDRANT_PORT=6333
ROCKETRIDE_COLLECTION_NAME=rti_docs

# OCR language settings for scanned documents (pipeline/ingestion.pipe)
# One of: latin, latin-extended, cyrillic, arabic, devanagari, chinese-simplified,
# chinese-traditional, japanese, korean, doctr, surya, trocr
ROCKETRIDE_OCR_PROFILE=devanagari
# One of: latin, latin-extended, cyrillic, arabic, devanagari, bengali,
# chinese-simplified, chinese-traditional, japanese, korean, thai, tamil, telugu
ROCKETRIDE_OCR_SCRIPT_FAMILY=devanagari

# Text-to-speech voice for the accessibility read-aloud feature (pipeline/query.pipe)
# English: af_heart, af_bella, am_adam ... | Hindi: hf_alpha, hf_beta, hm_omega, hm_psi
ROCKETRIDE_TTS_VOICE=af_heart

# Local app server port (not a RocketRide variable, read directly by app.py)
PORT=5000
